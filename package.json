{
  "name": "rugby-analytics-ecosystem",
  "version": "1.0.0",
  "description": "Unified platform integrating referee, analyst, and evaluator workflows for rugby match analysis",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest --coverage",
    "lint": "eslint .",
    "db:init": "mysql -u root -p < schema.sql",
    "db:seed": "node scripts/seed-data.js"
  },
  "keywords": [
    "rugby",
    "analytics",
    "sports",
    "api"
  ],
  "author": "Rugby Analytics Team",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "mysql2": "^3.6.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "jwt-simple": "^0.5.6",
    "pdfkit": "^0.13.0",
    "@google/generative-ai": "^0.1.3",
    "socket.io": "^4.7.2",
    "multer": "^1.4.5",
    "axios": "^1.4.0",
    "joi": "^17.11.0",
    "uuid": "^9.0.0",
    "express-async-errors": "^3.1.1"
  },
  "devDependencies": {
    "nodemon": "^3.0.2",
    "jest": "^29.7.0",
    "supertest": "^6.3.3",
    "eslint": "^8.52.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-plugin-import": "^2.29.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
